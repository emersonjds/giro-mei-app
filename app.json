{
  "expo": {
    "name": "giro-mei",
    "slug": "giro-mei",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/giromei-icon.png",
    "scheme": "giromei",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/giromei-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/giromei-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/giromei-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#004B44",
          "image": "./assets/images/giromei-logo.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/giromei-logo.png",
            "imageWidth": 120
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
